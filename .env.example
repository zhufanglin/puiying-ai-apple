# 数据库
DATABASE_URL=postgresql+asyncpg://puiying:puiying_dev@localhost:5432/puiying_apple

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256

# 应用
DEBUG=true

# 文件上传
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# AI 服务（可选，演示期可不填）
AI_API_URL=
AI_API_KEY=

# 百度 OCR（只供 OCR Worker 读取，不要写入前端 NEXT_PUBLIC_* 变量）
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
# 已有 access token 时可直接填写；与 AK/SK 二选一
BAIDU_OCR_ACCESS_TOKEN=
BAIDU_OCR_RECEIPT_MODE=handwriting
BAIDU_OCR_DOCUMENT_MODE=general_basic
BAIDU_OCR_TIMEOUT=20
