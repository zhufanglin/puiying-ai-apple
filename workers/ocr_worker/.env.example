# OCR 引擎：baidu / paddleocr / tesseract / auto
OCR_ENGINE=baidu

# 百度手写收据使用 handwriting；印刷文件可改为 accurate_basic
BAIDU_OCR_MODE=handwriting
BAIDU_OCR_API_KEY=replace_with_your_api_key
BAIDU_OCR_SECRET_KEY=replace_with_your_secret_key

# 可选：若由密钥管理系统提供短期 Token，可直接使用，设置后无需 AK/SK
BAIDU_OCR_ACCESS_TOKEN=
BAIDU_OCR_TIMEOUT=20
BAIDU_OCR_LANGUAGE=CHN_ENG
BAIDU_OCR_PDF_PAGE=1
